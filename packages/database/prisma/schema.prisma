// prisma/schema.prisma
// npx prisma migrate dev --name comments
// npx prisma generate
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  balance      Float?
  phoneNumber  String
  asset        Asset[]
  oderbook     Orderbook[]
  otp          Otp[]
  transactions Transaction[]
  watchList    watchList[]
}

model Orderbook {
  id           String        @id @default(uuid())
  type         String
  price        Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String
  assetId      String
  executed     Boolean       @default(false)
  qty          Int
  method       String        @default("sell")
  remainingQty Int           @default(0)
  asset        Asset         @relation(fields: [assetId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  transaction  Transaction[]
}

model Transaction {
  id          String    @id @default(uuid())
  amount      Float
  orderBookId String
  userId      String
  assetId     String
  executed    Boolean   @default(false)
  qty         Int
  type        String
  method      String    @default("sell")
  asset       Asset     @relation(fields: [assetId], references: [id])
  orderBook   Orderbook @relation(fields: [orderBookId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model Asset {
  id           String        @id @default(uuid())
  title        String
  userId       String
  image        String?
  maxPrice     Int           @default(0)
  buyPriceNo   Int           @default(0)
  buyPriceYes  Int           @default(0)
  sellPriceNo  Int           @default(0)
  sellPriceYes Int           @default(0)
  user         User          @relation(fields: [userId], references: [id])
  orders       Orderbook[]
  Transaction  Transaction[]
}

model Otp {
  id        String   @id @default(uuid())
  otp       Int      @unique
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Stocks {
  id                String              @id @default(uuid())
  name              String
  symbol            String
  lotsize           Int
  token             String
  exch_seg          String
  stock_candle_data stock_candle_data[]
  watchList         watchList[]
  signals           signals[]
}

model stock_candle_data {
  id          String   @id @default(uuid())
  open        Float
  high        Float
  low         Float
  close       Float
  volume      Int
  exchange    String
  symboltoken String
  stockId     String
  timestamp   DateTime
  interval    String
  stock       Stocks   @relation(fields: [stockId], references: [id])

  @@unique([stockId, timestamp])
  @@index([timestamp(sort: Desc)])
}

model watchList {
  id        String   @id @default(uuid())
  userId    String
  stockId   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stock     Stocks   @relation(fields: [stockId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isDeleted(sort: Desc)])
}

model smartApiToken {
  id           String   @id @default(uuid())
  authToken    String
  refreshToken String
  feedToken    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum SignalType {
  STRONG_BUY
  BUY
  IGNORE
}
model signals {
  id String @id @default(uuid())
  stockId String
  stock Stocks @relation(fields: [stockId], references: [id])
  signal SignalType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  totalScore Int
  level Json
  breakDown Json

  @@index([stockId])
}