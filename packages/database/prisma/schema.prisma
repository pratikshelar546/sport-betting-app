// prisma/schema.prisma
// npx prisma migrate dev --name comments
// npx prisma generate
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // This pulls from your .env file automatically
  url      = env("DATABASE_URL")
}
model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phoneNumber  String
  password     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  oderbook     Orderbook[]
  balance      Float?
  transactions Transaction[]
  asset        Asset[]
  otp          Otp[]
  watchList    watchList[]
}

model Orderbook {
  id        String   @id @default(uuid())
  type      String
  qty       Int
  remainingQty Int @default(0)
  price     Float
  method    String   @default("sell")
  executed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  transaction Transaction[]
}

model Transaction {
  id       String  @id @default(uuid())
  amount   Float
  qty      Int
  type     String
  method   String  @default("sell")
  executed Boolean @default(false)

  orderBookId String
  orderBook   Orderbook @relation(fields: [orderBookId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])
}

model Asset {
  id           String @id @default(uuid())
  title        String
  maxPrice     Int    @default(0)
  buyPriceYes  Int    @default(0)
  buyPriceNo   Int    @default(0)
  sellPriceYes Int    @default(0)
  sellPriceNo  Int    @default(0)
  userId       String
  user         User   @relation(fields: [userId], references: [id])

  image       String?
  orders      Orderbook[]
  Transaction Transaction[]
}

model Otp {
  id        String   @id @default(uuid())
  otp       Int      @unique
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Stocks {
  id String @id @default(uuid())
  name String
  symbol String
  lotsize Int
  token String
  exch_seg String
  stock_candle_data stock_candle_data[]
  watchList watchList[]
}

model stock_candle_data {
  id String @id @default(uuid())
  timestamp DateTime
  open Float
  high Float
  low Float
  close Float
  volume Int
  exchange String
  symboltoken String
  stockId String
  interval String 
  stock Stocks @relation(fields: [stockId], references: [id])
  @@unique([stockId, timestamp])    // to ensure we did not store duplicate data
  @@index([timestamp(sort: Desc)]) // to ensure we can query the data quickly
}


model watchList {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  stockId String
  stock Stocks @relation(fields: [stockId], references: [id])
  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, isDeleted(sort: Desc)])
}

model smartApiToken {
  id String @id @default(uuid())
  authToken String
  refreshToken String
  feedToken String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}